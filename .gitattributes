# Normalizar todos los archivos a LF en el repositorio
* text=auto eol=lf

# Archivos de texto explícitos
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Binarios — no tocar
*.glb  binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary








